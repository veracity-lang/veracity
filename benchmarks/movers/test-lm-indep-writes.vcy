/* commute_left { x = 1 } { y = 2 }
 * Expected: true
 * Writes to independent variables commute in both directions.
 *
 * ./vcy.exe infer benchmarks/movers/test-lm-indep-writes.vcy --prover cvc5 -ae
 */
int main(int argc, string[] argv) {
    int x = int_of_string(argv[1]);
    int y = int_of_string(argv[2]);
    commute_left _ {
        { x = 1; }
        { y = 2; }
    }
    return 0;
}
