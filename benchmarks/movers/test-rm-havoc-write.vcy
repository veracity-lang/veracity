/* commute_right { havoc c } { c = 1 }
 * Expected: true
 * Rationale: after (havoc c; c=1) we always get c=1. The reverse
 * (c=1; havoc c) can witness c=1 by choosing the havoc appropriately,
 * so a matching execution always exists.  Right-mover: true.
 *
 * ./vcy.exe infer benchmarks/movers/test-rm-havoc-write.vcy --prover cvc5 -ae
 */
int main(int argc, string[] argv) {
    int c = int_of_string(argv[1]);
    commute_right _ {
        { havoc c; }
        { c = 1; }
    }
    return 0;
}
