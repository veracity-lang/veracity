/* commute_right { a->value = 1 } { b->value = 2 }
 * Expected: !(b == a)
 * Writes to value fields of distinct heap nodes are a right-mover.
 * Same condition as the left-mover: heap value writes commute iff
 * the two location variables refer to different nodes.
 *
 * ./vcy.exe infer benchmarks/movers/test-rm-heap-value-writes.vcy --prover cvc5 -ae
 */
int main(int argc, string[] argv) {
    tloc a = new { 0 {} null };
    tloc b = new { 0 {} null };
    commute_right _ {
        { a->value = 1; }
        { b->value = 2; }
    }
    return 0;
}
