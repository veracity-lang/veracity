/* commute_right { a[i] = x } { a[j] = y }
 * Expected: !(i == j)
 * Writes to different array indices commute; same index does not.
 *
 * ./vcy.exe infer benchmarks/movers/test-rm-array-writes.vcy --prover cvc5 -ae
 */
int main(int argc, string[] argv) {
    int i = int_of_string(argv[1]);
    int j = int_of_string(argv[2]);
    int x = int_of_string(argv[3]);
    int y = int_of_string(argv[4]);
    int[] a = new int[]{0, 0};
    commute_right _ {
        { a[i] = x; }
        { a[j] = y; }
    }
    return 0;
}
